{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@callbreak/shared": ["../../packages/shared/src/index.ts"],
      "@callbreak/shared/*": ["../../packages/shared/src/*"]
    },
    "noEmit": true
  },
  "include": ["src", "../../packages/shared/src"]
}
